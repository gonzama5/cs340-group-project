<h1>Orders</h1>

<table>
    <thead>
        <tr>
            <th>Order ID</th>
            <th>Customer</th>
            <th>Date</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        {{#each orders}}
        <tr>
            <td>{{order_ID}}</td>
            <td>{{customer_name}}</td>
            <td>{{date}}</td>
            <td>
                <a href="/order-details/{{order_ID}}" class="btn" style="background-color: purple; color: white;">View Details</a>
            </td>
        </tr>
        {{else}}
        <tr>
            <td colspan="4">No orders found.</td>
        </tr>
        {{/each}}
    </tbody>
</table>

<div style="margin-top: 20px">
    <a href="/add-order" class="btn" style="background-color: blue">Add New Order</a>
    <a href="/delete-order" class="btn" style="background-color: red">Delete Order</a>
    <a href="/" class="btn" style="background-color: gray">Back to Home</a>
</div>