<h1>Orders</h1>

<table>
    <thead>
        <tr>
            <th>Order ID</th>
            <th>Customer</th>
            <th>Date</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        {{#each orders}}
        <tr>
            <td>{{order_ID}}</td>
            <td>{{customer_name}}</td>
            <td>{{date}}</td>
            <td>
                <a href="/order-details/{{order_ID}}" class="btn" style="background-color: purple; color: white;">View Details</a>
            </td>
        </tr>
        {{else}}
        <tr>
            <td colspan="4">No orders found.</td>
        </tr>
        {{/each}}
    </tbody>
</table>

<div style="margin-top: 20px">
    <a href="/add-customer" class="btn" style="background-color: blue; color: white;">Add New Customer</a>
    <a href="/delete-customer" class="btn" style="background-color: red; color: white;">Delete Customer</a>
    <a href="/" class="btn" style="background-color: gray; color: white;">Back to Home</a>
</div>