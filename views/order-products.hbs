<h1>Order Products</h1>
{{#if message}}
<div style="background-color: #d4edda; color: green ; padding: 15px; margin-bottom: 20px; border-radius: 4px; border: 1px solid #c3e6cb;">
    <strong>Success!</strong> {{message}}
</div>
{{/if}}

{{#if error}}
<div style="background-color: #dd9ca2; color: red; padding: 15px; margin-bottom: 20px; border-radius: 4px; border: 1px solid #f5c6cb;">
    <strong>Error!</strong> {{error}}
</div>
{{/if}}
<table>
    <thead>
        <tr>
            <th>Order ID</th>
            <th>Customer</th>
            <th>Product</th>
            <th>Quantity</th>
            <th>Order Date</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        {{#each orderProducts}}
        <tr>
            <td>{{order_ID}}</td>
            <td>{{customer_name}}</td>
            <td>{{product_name}}</td>
            <td>{{quantity}}</td>
            <td>{{order_date}}</td>
            <td>
                <a href="/update-order-product/{{order_ID}}/{{product_ID}}" class="btn" style="background-color: green; color: white;">Edit</a>
            </td>
        </tr>
        {{else}}
        <tr>
            <td colspan="6">No order products found.</td>
        </tr>
        {{/each}}
    </tbody>
</table>

<div style="margin-top: 20px">
    <a href="/add-customer" class="btn" style="background-color: blue; color: white;">Add New Customer</a>
    <a href="/delete-customer" class="btn" style="background-color: red; color: white;">Delete Customer</a>
    <a href="/" class="btn" style="background-color: gray; color: white;">Back to Home</a>
</div>