<h1>Update Order Product</h1>

<form action="/update-order-product/{{orderProduct.order_ID}}/{{orderProduct.product_ID}}" method="POST">
    <div class="form-group">
        <label for="order">Order:</label>
        <input type="text" id="order" value="Order #{{orderProduct.order_ID}} - {{orderProduct.customer_name}}" disabled>
    </div>

    <div class="form-group">
        <label for="product">Product:</label>
        <select id="product" name="product_ID" required>
            <option value="">-- Select a Product --</option>
            {{#each products}}
            <option value="{{product_ID}}" {{#if (eq product_ID ../orderProduct.product_ID)}}selected{{/if}}>
                {{name}}
            </option>
            {{/each}}
        </select>
    </div>

    <div class="form-group">
        <label for="quantity">Quantity:</label>
        <input type="number" id="quantity" name="quantity" value="{{orderProduct.quantity}}" min="1" required>
    </div>

    <button type="submit">Update Order Product</button>
</form>

<div style="margin-top: 20px">
    <a href="/order-products" class="btn" style="background-color: gray">Back to Order Products</a>
    <a href="/" class="btn" style="background-color: gray">Back to Home</a>
</div>