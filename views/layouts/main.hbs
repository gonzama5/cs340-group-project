<!DOCTYPE html>
<!--
    Citation for the following CSS styles and navigation bar design:
    Date: 3/14/2026
    Adapted from W3Schools CSS Navigation Bar tutorial and HTML Styles tutorial
    Source URL: https://www.w3schools.com/css/css_navbar.asp
    Source URL: https://www.w3schools.com/html/html_styles.asp
    Adapted to create a clean, professional navigation system for Samina's Corner Store inventory management system
-->

<!--
    Citation for the following font selection and typography:
    Date: 3/14/2026
    Adapted from W3Schools W3.CSS Fonts demonstration
    Source URL: https://www.w3schools.com/w3css/tryit.asp?filename=tryw3css_fonts_segoe_ui
    Adapted to implement Segoe UI font stack for improved readability and professional appearance
-->
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}} - Samina's Corner Store</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body { 
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            background-color: #ffffff;
            color: #1a1a1a;
            line-height: 1.5;
        }
        
        /* Main container */
        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 24px;
        }
        
        /* Header */
        .header {
            border-bottom: 2px solid #e0e0e0;
            padding-bottom: 16px;
            margin-bottom: 32px;
        }
        
        .header h1 {
            font-size: 1.8rem;
            font-weight: 500;
            letter-spacing: -0.5px;
            color: #000000;
        }
        
        .header p {
            color: #666666;
            font-size: 0.9rem;
            margin-top: 4px;
        }
        
        /* Navigation */
        .nav-container {
            border: 1px solid #e0e0e0;
            background-color: #ffffff;
            margin-bottom: 32px;
        }
        
        .nav-links {
            display: flex;
            flex-wrap: wrap;
        }
        
        .nav-section {
            display: flex;
            align-items: center;
            padding: 12px 16px;
            border-right: 1px solid #e0e0e0;
        }
        
        .nav-section:last-child {
            border-right: none;
        }
        
        .nav-section span {
            font-weight: 600;
            color: #000000;
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-right: 12px;
        }
        
        .nav-links a {
            color: #333333;
            text-decoration: none;
            padding: 4px 8px;
            margin: 0 2px;
            font-size: 0.9rem;
            border: 1px solid transparent;
        }
        
        .nav-links a:hover {
            border: 1px solid #cccccc;
            background-color: #f5f5f5;
        }
        
        /* Home link styling */
        .nav-home {
            font-weight: 500;
            background-color: #fafafa;
            border-right: 1px solid #e0e0e0;
            padding: 12px 20px;
        }
        
        .nav-home a {
            font-weight: 500;
            margin: 0;
            padding: 4px 12px;
        }
        
        /* Special buttons  */
        .nav-links a.test-link {
            background-color: #dc3545;
            color: white;
            border: 1px solid #dc3545;
        }
        
        .nav-links a.test-link:hover {
            background-color: #c82333;
            border-color: #c82333;
        }
        
        .nav-links a.reset-link {
            background-color: #007bff;
            color: white;
            border: 1px solid #007bff;
        }
        
        .nav-links a.reset-link:hover {
            background-color: #0069d9;
            border-color: #0069d9;
        }
        
        /* Tables */
        table {
            width: 100%;
            border: 1px solid #e0e0e0;
            border-collapse: collapse;
            margin-bottom: 24px;
            font-size: 0.9rem;
        }
        
        th {
            background-color: #f5f5f5;
            color: #000000;
            font-weight: 600;
            padding: 12px;
            text-align: left;
            border-bottom: 2px solid #cccccc;
        }
        
        td {
            padding: 12px;
            border-bottom: 1px solid #e0e0e0;
        }
        
        tr:last-child td {
            border-bottom: none;
        }
        
        /* Buttons */
        .btn {
            display: inline-block;
            padding: 6px 12px;
            border: 1px solid #cccccc;
            background-color: #ffffff;
            color: #333333;
            text-decoration: none;
            font-size: 0.85rem;
            border-radius: 0;
            cursor: pointer;
            transition: all 0.2s;
        }
        
        .btn:hover {
            background-color: #f5f5f5;
            border-color: #999999;
        }
        
        .btn-primary {
            background-color: #007bff;
            border-color: #007bff;
            color: white;
        }
        
        .btn-primary:hover {
            background-color: #0069d9;
            border-color: #0069d9;
        }
        
        .btn-danger {
            background-color: #dc3545;
            border-color: #dc3545;
            color: white;
        }
        
        .btn-danger:hover {
            background-color: #c82333;
            border-color: #c82333;
        }
        
        .btn-success {
            background-color: #28a745;
            border-color: #28a745;
            color: white;
        }
        
        .btn-success:hover {
            background-color: #218838;
            border-color: #218838;
        }
        
        /* Forms */
        .form-container {
            border: 1px solid #e0e0e0;
            padding: 24px;
            max-width: 600px;
            margin: 0 auto;
            background-color: #ffffff;
        }
        
        .form-group {
            margin-bottom: 20px;
        }
        
        .form-group label {
            display: block;
            margin-bottom: 6px;
            font-weight: 500;
            font-size: 0.9rem;
            color: #000000;
        }
        
        .form-group input,
        .form-group select {
            width: 100%;
            padding: 8px 12px;
            border: 1px solid #cccccc;
            border-radius: 0;
            font-size: 0.9rem;
            background-color: #ffffff;
        }
        
        .form-group input:focus,
        .form-group select:focus {
            outline: none;
            border-color: #666666;
        }
        
        .form-group input[readonly] {
            background-color: #f5f5f5;
            border-color: #e0e0e0;
            color: #666666;
        }
        
        /* Messages */
        .message {
            padding: 12px 16px;
            margin-bottom: 20px;
            border: 1px solid transparent;
        }
        
        .message.success {
            background-color: #f0f9f0;
            border-color: #28a745;
            color: #1e7e34;
        }
        
        .message.error {
            background-color: #fef2f2;
            border-color: #dc3545;
            color: #b21f2d;
        }
        
        /* Footer */
        .footer {
            margin-top: 48px;
            padding: 24px 0 0;
            border-top: 1px solid #e0e0e0;
            text-align: center;
            color: #666666;
            font-size: 0.85rem;
        }
        
        /* Headings */
        h1, h2, h3 {
            font-weight: 500;
            letter-spacing: -0.3px;
        }
        
        h1 {
            font-size: 2rem;
            margin-bottom: 16px;
        }
        
        h2 {
            font-size: 1.5rem;
            margin: 24px 0 16px;
            padding-bottom: 8px;
            border-bottom: 1px solid #e0e0e0;
        }
        
        /* Responsive */
        @media (max-width: 1024px) {
            .nav-links {
                flex-direction: column;
            }
            
            .nav-section {
                border-right: none;
                border-bottom: 1px solid #e0e0e0;
                flex-wrap: wrap;
            }
            
            .nav-section:last-child {
                border-bottom: none;
            }
        }
        
        @media (max-width: 768px) {
            .container {
                padding: 16px;
            }
            
            table {
                display: block;
                overflow-x: auto;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>Samina's Corner Store</h1>
            <p>Inventory Management System</p>
        </div>
        
        <div class="nav-container">
            <div class="nav-links">
                <div class="nav-section">
                    <span>Home</span>
                    <a href="/">Home</a>
                </div>
                
                <div class="nav-section">
                    <span>Browse</span>
                    <a href="/customers">Customers</a>
                    <a href="/orders">Orders</a>
                    <a href="/products">Products</a>
                    <a href="/product-types">Types</a>
                    <a href="/suppliers">Suppliers</a>
                    <a href="/order-products">Order Products</a>
                </div>
                
                <div class="nav-section">
                    <span>Add</span>
                    <a href="/add-customer">Customer</a>
                    <a href="/add-order">Order</a>
                    <a href="/add-product">Product</a>
                    <a href="/add-product-type">Type</a>
                    <a href="/add-supplier">Supplier</a>
                    <a href="/add-order-product">Order Item</a>
                </div>
                
                <div class="nav-section">
                    <span>Delete</span>
                    <a href="/delete-customer">Customer</a>
                    <a href="/delete-order">Order</a>
                    <a href="/delete-product">Product</a>
                    <a href="/delete-product-type">Type</a>
                    <a href="/delete-supplier">Supplier</a>
                    <a href="/delete-order-product">Order Products</a>
                </div>
                
                <div class="nav-section">
                    <span>Tools</span>
                    <a href="/delete-test-customer" class="test-link">Test Delete</a>
                    <a href="/reset-database" class="reset-link">Reset DB</a>
                </div>
            </div>
        </div>
        
        {{{body}}}
        
        <div class="footer">
            <p>© 2026 Team 31 · CS340 Portfolio Project</p>
        </div>
    </div>
</body>
</html>