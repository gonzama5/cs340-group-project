<h1>Add New Supplier</h1>

<form action="/add-supplier" method="POST">
    <div class="form-group">
        <label for="name">Supplier Name:</label>
        <input type="text" id="name" name="name" placeholder="e.g., Fresh Foods Inc." required>
    </div>

    <div class="form-group">
        <label for="email">Email:</label>
        <input type="email" id="email" name="email" placeholder="contact@company.com" required>
    </div>

    <button type="submit">Add Supplier</button>
</form>

<div style="margin-top: 20px">
    <a href="/suppliers" class="btn" style="background-color: gray">Back to Suppliers</a>
    <a href="/" class="btn" style="background-color: gray">Back to Home</a>
</div>