<h1>Add Product to Order</h1>

<form action="/add-order-product" method="POST">
    <div class="form-group">
        <label for="order_ID">Select Order:</label>
        <select id="order_ID" name="order_ID" required>
            <option value="">-- Select an Order --</option>
            <option value="1">Order #1 - 2026-02-01</option>
            <option value="2">Order #2 - 2026-02-01</option>
            <option value="3">Order #3 - 2026-02-01</option>
            <option value="4">Order #4 - 2026-02-01</option>
        </select>
    </div>

    <div class="form-group">
        <label for="product_ID">Select Product:</label>
        <select id="product_ID" name="product_ID" required>
            <option value="">-- Select a Product --</option>
            <option value="1">Apple Juice - $3.99</option>
            <option value="2">Potato Chips - $5.99</option>
            <option value="3">Milk - $4.25</option>
            <option value="4">Bread - $2.99</option>
            <option value="5">Soda - $4.99</option>
        </select>
    </div>

    <div class="form-group">
        <label for="quantity">Quantity:</label>
        <input type="number" id="quantity" name="quantity" min="1" value="1" required>
    </div>

    <button type="submit">Add to Order</button>
</form>

<div style="margin-top: 20px">
    <a href="/order-products" class="btn" style="background-color: gray">Back to Order Products</a>
    <a href="/orders" class="btn" style="background-color: gray">Back to Orders</a>
    <a href="/" class="btn" style="background-color: gray">Back to Home</a>
</div>