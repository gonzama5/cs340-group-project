<h1>Add New Product Type</h1>

<form action="/add-product-type" method="POST">
    <div class="form-group">
        <label for="name">Category Name:</label>
        <input type="text" id="name" name="name" placeholder="e.g., Beverages, Snacks, Dairy" required>
    </div>
    
    <button type="submit">Add Product Type</button>
</form>

<div style="margin-top: 20px">
    <a href="/product-types" class="btn" style="background-color: gray">Back to Product Types</a>
    <a href="/" class="btn" style="background-color: gray">Back to Home</a>
</div>